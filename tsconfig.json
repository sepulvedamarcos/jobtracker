{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",

    "lib": ["ES2022"],
    "types": ["node"],

    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}