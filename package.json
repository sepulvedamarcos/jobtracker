{
  "name": "jobtracker",
  "version": "0.4.6",
  "description": "TUI para búsqueda y seguimiento de empleo",
  "repository": {
    "type": "git",
    "url": "https://github.com/sepulvedamarcos/jobtracker"
  },
  "readme": "README-NPM-en.md",
  "bin": {
    "jobtracker": "./dist/infrastructure/adapters/cli/app.js"
  },
  "main": "./dist/infrastructure/adapters/cli/app.js",
  "scripts": {
    "build": "tsc",
    "dev": "JOBTRACKER_DEV=true tsx src/infrastructure/adapters/cli/app.tsx",
    "dev:nosp": "JOBTRACKER_DEV=true tsx src/infrastructure/adapters/cli/app.tsx --nosplash",
    "dev:silent": "JOBTRACKER_DEV=true tsx src/infrastructure/adapters/cli/app.tsx --silent",
    "dev:add": "JOBTRACKER_DEV=true tsx src/infrastructure/adapters/cli/app.tsx --addKey",
    "dev:del": "JOBTRACKER_DEV=true tsx src/infrastructure/adapters/cli/app.tsx --delKey",
    "dev:plugin": "JOBTRACKER_DEV=true tsx src/infrastructure/adapters/cli/app.tsx --addPlugin",
    "dev:delplugin": "JOBTRACKER_DEV=true tsx src/infrastructure/adapters/cli/app.tsx --delete-plugin",
    "dev:list-plugins": "JOBTRACKER_DEV=true tsx src/infrastructure/adapters/cli/app.tsx --list-plugins",
    "dev:sync-plugins": "JOBTRACKER_DEV=true tsx src/infrastructure/adapters/cli/app.tsx --sync-plugins",
    "dev:list-keywords": "JOBTRACKER_DEV=true tsx src/infrastructure/adapters/cli/app.tsx --list-keywords",
    "-   separador": "-----------------------------------------------------------------------------------------",
    "--  separador": "----------------------------------------------------------------------------------------",
    "start": "tsx src/infrastructure/adapters/cli/app.tsx",
    "start:nosp": "tsx src/infrastructure/adapters/cli/app.tsx --nosplash",
    "start:silent": "tsx src/infrastructure/adapters/cli/app.tsx --silent",
    "start:add": "tsx src/infrastructure/adapters/cli/app.tsx --addKey",
    "start:del": "tsx src/infrastructure/adapters/cli/app.tsx --delKey",
    "start:plugin": "tsx src/infrastructure/adapters/cli/app.tsx --addPlugin",
    "start:delplugin": "tsx src/infrastructure/adapters/cli/app.tsx --delete-plugin",
    "start:list-plugins": "tsx src/infrastructure/adapters/cli/app.tsx --list-plugins",
    "start:sync-plugins": "tsx src/infrastructure/adapters/cli/app.tsx --sync-plugins",
    "start:list-keywords": "tsx src/infrastructure/adapters/cli/app.tsx --list-keywords",
    "--- separador": "----------------------------------------------------------------------------------------",
    "print:jobs": "tsx src/scripts/printJobs.ts",
    "analyze": "tsx src/scripts/analyzeCommits.ts",
    "commit": "cz",
    "release": "tsx src/scripts/analyzeCommits.ts",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "prepare": "husky"
  },
  "keywords": [
    "job",
    "tracker",
    "tui",
    "employment"
  ],
  "author": "Marcos Sepulveda",
  "license": "ISC",
  "overrides": {
    "iron": "^7.0.1",
    "boom": "^10.0.0",
    "hoek": "^10.0.0",
    "b64": "^6.0.0",
    "cryptiles": "^6.0.0"
  },
  "type": "module",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "commander": "^14.0.3",
    "env-paths": "^4.0.0",
    "ink": "^7.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-select-input": "^6.2.0",
    "@hapi/iron": "^7.0.1",
    "jszip": "^3.10.1",
    "node-file-dialog": "^1.0.3",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "commitizen": "^4.3.1",
    "commitlint": "^20.5.0",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
