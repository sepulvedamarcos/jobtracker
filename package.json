{
  "name": "jobtracker",
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "clear && tsx --tsconfig tsconfig.json src/infrastructure/adapters/cli/app.tsx",
    "dev:silent": "clear && ts-node src/infrastructure/adapters/cli/app.tsx --silent",
    "dev:add": "clear && ts-node src/infrastructure/adapters/cli/app.tsx --add-keyword",
    "dev:plugin": "clear && JOBTRACKER_PLUGIN_DEV=true tsx --tsconfig tsconfig.json src/infrastructure/adapters/cli/app.tsx",
    "dev:plugin:find": "JOBTRACKER_PLUGIN_DEV=true && clear && tsx --tsconfig tsconfig.json src/infrastructure/adapters/cli/app.tsx --find",
    "print:jobs": "tsx src/scripts/printJobs.ts",
    "commit": "cz",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "commander": "^14.0.3",
    "env-paths": "^4.0.0",
    "ink": "^7.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-select-input": "^6.2.0",
    "iron": "^5.0.6",
    "jszip": "^3.10.1",
    "node-file-dialog": "^1.0.3",
    "react": "^19.2.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "commitizen": "^4.3.1",
    "commitlint": "^20.5.0",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "standard-version": "^9.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
